# === APP ===
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === AGENCY PLATFORM (multi-tenant) ===
# URL platformy agencyjnej (np. https://agency.twojadomena.pl)
# Gdy ustawione, app działa w trybie multi-tenant — tenant rozpoznawany po domenie
AGENCY_PLATFORM_URL=
# Musi zgadzać się z AGENCY_API_SECRET w agency-platform
AGENCY_API_SECRET=

# === NEON ===
# Przez Vercel Marketplace: vercel env pull .env.local  (ustawia poniższe automatycznie)
# Ręcznie z neon.tech: "Pooled connection" → DATABASE_URL, "Direct connection" → DATABASE_URL_UNPOOLED
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.neon.tech/neondb?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
# Alternatywnie lokalnie (zamiast DATABASE_URL_UNPOOLED):
# DIRECT_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# === NEXTAUTH ===
# Generuj: openssl rand -base64 32
AUTH_SECRET=
# Na Vercel: AUTH_URL nie jest wymagany — NextAuth wykrywa URL automatycznie
AUTH_URL=http://localhost:3000

# === CARDDAV ===
# Synchronizacja kontaktów klientów z telefonami firmowymi
# login: wartość CARDDAV_SYNC_USER (domyślnie "sync"), hasło: CARDDAV_SYNC_PASSWORD
# Adres serwera do wpisania w telefonie: https://twoja-domena/api/carddav/
CARDDAV_SYNC_USER=sync
CARDDAV_SYNC_PASSWORD=

# === STRIPE (opcjonalne — przyszłe rozszerzenie) ===
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# === RESEND (opcjonalne — przyszłe rozszerzenie) ===
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@twojadomena.com

# === VERCEL (do synca zmiennych przez API) ===
VERCEL_ACCESS_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# === DEPLOY NA VERCEL ===
# 1. npm i -g vercel
# 2. vercel link          (połącz projekt)
# 3. vercel env pull .env.local   (pobierz zmienne z Vercel)
# 4. Wymagane zmienne na Vercel:
#    DATABASE_URL, DATABASE_URL_UNPOOLED, AUTH_SECRET
#    (AUTH_URL nie jest potrzebny — Vercel ustawia VERCEL_URL automatycznie)
# 5. prisma migrate deploy  (dla produkcji, nie migrate dev)
